# identifAI secrets.
# Copy this file to ~/.config/identifAI/.env and fill in the two values.
# `chmod 600 ~/.config/identifAI/.env` after editing.
#
# Non-secret settings (model, USE_WEB_SEARCH, daily limit, etc.) live in
# config.json at the project root. Anything you set here as an env var
# will override config.json for that key (useful under systemd/CI).

# REQUIRED. Token from @BotFather on Telegram (/newbot).
TELEGRAM_BOT_TOKEN=

# REQUIRED. Your numeric Telegram user_id. Comma-separated if more than one.
# Easy: message @userinfobot on Telegram, it replies with your id.
ALLOWED_TELEGRAM_USER_IDS=
