# identifAI configuration.
# Copy this file to ~/.config/identifAI/.env and fill in the two required values.
# `chmod 600 ~/.config/identifAI/.env` after editing.

# REQUIRED. Token from @BotFather on Telegram (/newbot).
TELEGRAM_BOT_TOKEN=

# REQUIRED. Your numeric Telegram user_id. Comma-separated if more than one.
# To find it: message your bot once, then open in browser:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "from": {"id": 123456789, ...}  -> 123456789 is your user_id.
ALLOWED_TELEGRAM_USER_IDS=

# OPTIONAL.
DAILY_IMAGE_LIMIT=50
MODEL=claude-sonnet-4-6
USE_WEB_SEARCH=true
# CLAUDE_BIN=/home/digital/.local/bin/claude   # set absolute path if PATH is restricted (e.g. systemd)
# RESPONSES_DIR=./responses
